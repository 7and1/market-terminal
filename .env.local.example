# -------------------------------------------------
# Bright Data
# https://brightdata.com -> Proxies & Scraping Infrastructure
# -------------------------------------------------
BRIGHTDATA_API_TOKEN=your_brightdata_api_token_here
BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker_1
BRIGHTDATA_SERP_ZONE=serp_1

# -------------------------------------------------
# AI -- OpenRouter
# -------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1
OPENROUTER_MODEL_FALLBACKS=mistralai/mistral-small-3.2-24b-instruct,qwen/qwen3.5-flash-02-23

# -------------------------------------------------
# PostgreSQL (Supabase on VPS)
# -------------------------------------------------
DATABASE_URL=your_postgresql_connection_string

# -------------------------------------------------
# Operator control plane
# -------------------------------------------------
OPERATOR_TOKEN=replace_with_a_long_random_token
MIN_EVIDENCE_FOR_READY=3
DAILY_BRIGHTDATA_CALL_LIMIT=2000
DAILY_OPENROUTER_CALL_LIMIT=1500
# Optional ops webhook. Monitor dispatch posts provider usage warnings here when daily usage exceeds 80%.
# ALERT_WEBHOOK=https://example.com/ops-alert
RAW_DOC_REUSE_HOURS=6
DEEP_SCRAPE_COUNT=8
RATE_LIMIT_BACKEND=pg

# -------------------------------------------------
# Optional
# -------------------------------------------------

# Resend-backed subscription confirmation emails. Leave unset to disable subscription UI/API.
# RESEND_API_KEY=re_...
# EMAIL_FROM=TrendAnalysis.ai <alerts@trendanalysis.ai>
# EMAIL_REPLY_TO=ops@trendanalysis.ai

# Allow clients to pass their own API key in the request body.
# Useful for local demos -- do NOT enable in production.
# ALLOW_CLIENT_API_KEYS=true

# Use forwarded client IPs for public API rate limiting.
# Enable only behind a trusted reverse proxy that strips/rewrites these headers.
# The app prefers x-real-ip, then the last x-forwarded-for hop.
# TRUST_PROXY_HEADERS=true
