{
  "name": "@brightdata/market-terminal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "npx @opennextjs/cloudflare build",
    "preview:cf": "npx wrangler dev",
    "preview:openclaw": "bash scripts/openclaw-preview.sh",
    "deploy:cf": "npx wrangler pages deploy",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test --config playwright.config.ts",
    "test:browser:install": "playwright install chromium",
    "test:browser:openclaw": "bash scripts/openclaw-browser-validate.sh",
    "cleanup:sessions": "node scripts/cleanup-expired-sessions.mjs",
    "monitors:dispatch": "node scripts/dispatch-monitors.mjs",
    "schema:apply": "node scripts/apply-schema.mjs",
    "keyword-research": "npx tsx scripts/keyword-research.ts",
    "seed:canonical": "npx tsx scripts/seed-canonical-heads.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@supabase/supabase-js": "^2.95.2",
    "class-variance-authority": "0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-intl": "4.8.3",
    "openai": "^6.18.0",
    "pg": "^8.13.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-force-graph-2d": "^1.29.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@opennextjs/cloudflare": "1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.11.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
